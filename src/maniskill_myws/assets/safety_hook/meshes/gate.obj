# Safety-hook gate (screw-gate / clasp) mesh.
# Units: meters. Local origin at the HINGE POINT.
# Hinge point in base frame: (0.030, 0, 0.140) — see mobility.urdf joint origin.
# Gate extends DOWNWARD from hinge in -Z direction (in gate local frame).
# When joint angle=0 (closed): gate tip rests in the nose of the frame (~z=-0.130).
# Thickness Y: 0.020 m (fits within frame thickness).
# All faces triangles, CCW winding.

o gate

# ======================================================
# Box A: Main gate rod
# In gate local frame: center (0, 0, -0.065), half (0.006, 0.008, 0.065)
# z: 0.000 to -0.130
# ======================================================
v -0.006 -0.008  0.000
v  0.006 -0.008  0.000
v  0.006  0.008  0.000
v -0.006  0.008  0.000
v -0.006 -0.008 -0.130
v  0.006 -0.008 -0.130
v  0.006  0.008 -0.130
v -0.006  0.008 -0.130

# ======================================================
# Box B: Locking collar (thicker zone near top, simulates screw sleeve)
# center (0, 0, -0.020), half (0.010, 0.011, 0.018)
# z: -0.002 to -0.038
# ======================================================
v -0.010 -0.011 -0.002
v  0.010 -0.011 -0.002
v  0.010  0.011 -0.002
v -0.010  0.011 -0.002
v -0.010 -0.011 -0.038
v  0.010 -0.011 -0.038
v  0.010  0.011 -0.038
v -0.010  0.011 -0.038

# ======================================================
# Box C: Tip block (bottom of gate, wedge tip that fits into nose)
# center (0, 0, -0.122), half (0.007, 0.009, 0.010)
# z: -0.112 to -0.132
# ======================================================
v -0.007 -0.009 -0.112
v  0.007 -0.009 -0.112
v  0.007  0.009 -0.112
v -0.007  0.009 -0.112
v -0.007 -0.009 -0.132
v  0.007 -0.009 -0.132
v  0.007  0.009 -0.132
v -0.007  0.009 -0.132

