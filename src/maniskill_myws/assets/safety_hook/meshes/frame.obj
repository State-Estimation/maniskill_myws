v -0.024 -0.005  0.000
v -0.024  0.005  0.000
v -0.036  0.005  0.000
v -0.036 -0.005  0.090
v -0.024 -0.005  0.090
v -0.024  0.005  0.090
v -0.036  0.005  0.090

